# Copy to .env and adjust before running docker compose outside local development.

# Secret used to sign/verify JWTs across services. Must be at least 32 characters.
JWT_SECRET=dev-secret-change-me-please-32-bytes-min!

# Credentials for the seeded admin account (auth-service, dev convenience only).
SEED_ADMIN_EMAIL=admin@helpdesk.local
SEED_ADMIN_PASSWORD=ChangeMe123!
